{
  "name": "Stage 3: Dialog",
  "description": "Multi-turn interactions: a correction followed by a context-dependent follow-up. Tests the full organ metabolism across turns.",
  "consolidate_before": false,
  "episodes": [
    {
      "id": "s3_ship_log",
      "initial_request": "Show the log.",
      "default_response": "I'll show the system error log.",
      "correction_utterance": "No, 'log' means the captain's journal.",
      "corrected_label": "captain's journal",
      "corrected_response": "I'll show the captain's journal.",
      "domain": "nautical",
      "probes": [
        {"request": "Now read the latest entry in it.", "expected": "captain's journal", "category": "transfer", "match_mode": "sense"},
        {"request": "Log the system crash.", "expected": "system error log", "category": "scope", "match_mode": "sense"}
      ]
    },
    {
      "id": "s3_official_file",
      "initial_request": "File the report.",
      "default_response": "I'll save the report to disk.",
      "correction_utterance": "No, 'file' means submit it officially.",
      "corrected_label": "submit officially",
      "corrected_response": "I'll submit the report officially.",
      "domain": "bureaucracy",
      "probes": [
        {"request": "Now file the quarterly update.", "expected": "submit officially", "category": "transfer", "match_mode": "sense"},
        {"request": "Save the file.", "expected": "computer file", "category": "scope", "match_mode": "sense"}
      ]
    },
    {
      "id": "s3_map_key",
      "initial_request": "Check the key.",
      "default_response": "I'll check the keyboard key.",
      "correction_utterance": "No, 'key' means the map legend.",
      "corrected_label": "map legend",
      "corrected_response": "I'll check the map legend.",
      "domain": "cartography",
      "probes": [
        {"request": "Now read the symbols from it.", "expected": "map legend", "category": "transfer", "match_mode": "sense"},
        {"request": "Press the key.", "expected": "keyboard key", "category": "scope", "match_mode": "sense"}
      ]
    },
    {
      "id": "s3_music_record",
      "initial_request": "Play the record.",
      "default_response": "I'll play the database record.",
      "correction_utterance": "No, 'record' means the music record.",
      "corrected_label": "music record",
      "corrected_response": "I'll play the music record.",
      "domain": "music",
      "probes": [
        {"request": "Now queue the next track.", "expected": "music record", "category": "transfer", "match_mode": "sense"},
        {"request": "Insert the record.", "expected": "database record", "category": "scope", "match_mode": "sense"}
      ]
    }
  ]
}
